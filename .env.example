# =============================================================================
# Feature Forge — Environment Variables (Secrets Only)
# =============================================================================
# Non-sensitive configuration defaults are in config/settings.yaml.
# Override them via FF_* env vars — no need to put them in .env.
#
# To set up:
#   1. cp .env.example .env
#   2. Fill in your secret values
#   3. dotenvx encrypt
#
# The encrypted .env is safe to commit. The .env.keys file must NEVER be committed.
# =============================================================================

# ── LLM API Key (single key for all providers) ───────────────────────────────
# A single API key that works across all LLM providers (or your proxy/router key).
# On config load, this is automatically propagated to:
#   DEEPSEEK_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY, GEMINI_API_KEY
FF_LLM__API_KEY=

# ── Experiment Tracking ─────────────────────────────────────────────────────
WANDB_API_KEY=

# ── Observability (Langfuse) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
