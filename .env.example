# =============================================================================
# Feature Forge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then encrypt with dotenvx:
#   dotenvx encrypt
#
# The encrypted .env is safe to commit. The .env.keys file must NEVER be committed.
# =============================================================================

# ── Core Pipeline ────────────────────────────────────────────────────────────
# Task type: classification | regression
FF_TASK=classification
# Evaluation metric: auc | acc | f1 | rmse | mae | r2
FF_METRIC=auc
# Number of feature engineering rounds
FF_N_ROUNDS=4
FF_RANDOM_STATE=42
FF_VERBOSE=1

# ── LLM Configuration (FF_LLM__*) ───────────────────────────────────────────
# Default provider: deepseek-chat (prime), or use litellm prefix:
#   "openai/gpt-4o", "anthropic/claude-3-5-sonnet-20241022", "gemini/gemini-2.0-flash"
FF_LLM__MODEL=deepseek-chat
FF_LLM__API_KEY=
FF_LLM__BASE_URL=https://api.deepseek.com
FF_LLM__TEMPERATURE=0.2
FF_LLM__MAX_TOKENS=4096
FF_LLM__CACHE_RESPONSES=true
FF_LLM__MAX_CONCURRENT_CALLS=3

# ── DeepSeek (Native JSON Mode — Prime Integration) ──────────────────────────
DEEPSEEK_API_KEY=

# ── LiteLLM (All Other LLM Providers) ───────────────────────────────────────
# Uncomment the provider(s) you need. LiteLLM auto-detects the correct API
# from the model prefix (e.g. "openai/gpt-4o" → uses OPENAI_API_KEY).
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# AZURE_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Experiment Tracking ─────────────────────────────────────────────────────
# Backend: wandb | mlflow | none
FF_TRACKER__BACKEND=wandb
FF_TRACKER__PROJECT=feature-forge
# FF_TRACKER__ENTITY=

# WandB
WANDB_API_KEY=
# WANDB_MODE=offline

# MLflow (if using mlflow backend)
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_EXPERIMENT_NAME=feature-forge

# ── Observability (Langfuse) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Evaluation ───────────────────────────────────────────────────────────────
FF_EVALUATION__CV_FOLDS=5
FF_EVALUATION__TEST_SIZE=0.4

# ── Router Agent ─────────────────────────────────────────────────────────────
# Strategy: data_driven | performance_driven | hybrid | llm
FF_ROUTER__STRATEGY=hybrid
# FF_ROUTER__MAX_AGENTS=
FF_ROUTER__MIN_AGENTS=1

# ── Memory ───────────────────────────────────────────────────────────────────
FF_MEMORY__MAX_SIZE=100
FF_MEMORY__PERSISTENCE_DIR=memory_files/agent_memories
